# =========================================================
# ERP TUMOMITO - Variables de Entorno
# Copia este archivo como .env y completa los valores
# =========================================================

# Base de datos (obtener de Supabase > Settings > Database)
DATABASE_URL=postgresql://postgres:[TU-PASSWORD]@db.[TU-PROJECT-REF].supabase.co:5432/postgres

# Seguridad JWT
SECRET_KEY=CAMBIA-ESTO-POR-UNA-CLAVE-SEGURA-DE-AL-MENOS-32-CARACTERES
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Entorno
ENVIRONMENT=production

# CORS - URL del frontend en Render
FRONTEND_URL=https://tumomito-frontend.onrender.com
